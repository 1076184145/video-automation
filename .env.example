# Leave these blank for the normal project-relative defaults.
# Set absolute paths only in your private .env, never in commits.
VIDEO_AUTOMATION_ROOT=
INPUT_RECORDINGS_DIR=
JOBS_DIR=
LOGS_DIR=

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
AUDIOWAVEFORM_PATH=audiowaveform
# Optional Rust/PyO3 fallback accelerator for waveform.json when audiowaveform is unavailable.
# Keep true; set false to diagnose native extension issues or force the pure Python fallback.
NATIVE_WAVEFORM_ENABLED=true
# Optional Rust/PyO3 accelerator for cut planning and clip scoring. Set false to force the pure Python planner.
NATIVE_CUTS_ENABLED=true
# Export audio_hq.flac for downstream audio editing / UVR. Set false for faster jobs and less disk IO.
HIGH_QUALITY_AUDIO_ENABLED=true

WHISPER_BIN=whisper
# Transcription backend options:
# - funasr-whisper: Chinese-first mode. Try FunASR, then fall back to faster-whisper.
# - funasr: require FunASR only.
# - faster-whisper: require faster-whisper only.
# - cli: use the whisper command-line tool.
WHISPER_BACKEND=funasr-whisper
WHISPER_MODEL=large-v3
WHISPER_MODEL_FALLBACKS=large-v3-turbo,medium
WHISPER_LANGUAGE=zh
WHISPER_INITIAL_PROMPT=
WHISPER_TIMEOUT_MIN_SECONDS=300
WHISPER_TIMEOUT_MULTIPLIER=10
WHISPER_WORD_TIMESTAMPS=true
WHISPER_VAD_FILTER=true
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=int8_float16
FASTER_WHISPER_BATCH_SIZE=8

# Optional Chinese ASR backend. WHISPER_BACKEND=funasr-whisper tries it first and falls back to faster-whisper.
# First run downloads models through FunASR/ModelScope or Hugging Face.
FUNASR_MODEL=paraformer-zh
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc
FUNASR_DEVICE=cuda:0
FUNASR_HOTWORDS=
FUNASR_BATCH_SIZE_S=300
FUNASR_MAX_SEGMENT_MS=60000
# Recommended: true. Reuses the isolated FunASR model process between jobs,
# removing repeated 20-30 second model startup cost. Set false for diagnosis.
FUNASR_PERSISTENT_WORKER=true

# Optional ffmpeg filter applied only to audio.wav used for transcription.
# Example: highpass=f=80,lowpass=f=7600,afftdn
TRANSCRIBE_AUDIO_FILTER=

PROFANITY_WORDS=操,艹,卧槽,我操,傻逼,牛逼,装逼,妈的,他妈的,草泥马
SUBTITLE_CENSOR_REPLACEMENT=[哔]
SUBTITLE_REPLACEMENTS=
SUBTITLE_MIN_DURATION_SECONDS=0.3
# Drop long, sparse subtitle events that are often background music vocals rather than speech.
# Raise SUBTITLE_MUSIC_VOCAL_MIN_CHARS_PER_SECOND for more aggressive filtering; set enabled=false to disable.
SUBTITLE_MUSIC_VOCAL_FILTER_ENABLED=true
SUBTITLE_MUSIC_VOCAL_MIN_DURATION_SECONDS=1.5
SUBTITLE_MUSIC_VOCAL_MIN_CHARS_PER_SECOND=1.8
SUBTITLE_MUSIC_VOCAL_MIN_AVG_PROBABILITY=0.0
# Optional comma-separated lyric/song fragments to suppress from burned subtitles.
# Example: SUBTITLE_MUSIC_VOCAL_PATTERNS=爱我还是他,风吹沙,叠莲花,千古
SUBTITLE_MUSIC_VOCAL_PATTERNS=

FILE_STABLE_SECONDS=8
POLL_INTERVAL_SECONDS=5
SILENCE_MIN_LENGTH_SECONDS=0.8
SILENCE_MIN_GAP_SECONDS=0.35
CUT_MIN_CLIP_SECONDS=2.0
CUT_MERGE_GAP_SECONDS=1.5
SILENCE_THRESHOLD_DB=-35
FREEZE_NOISE_DB=-60
FREEZE_MIN_DURATION_SECONDS=2
SCENE_THRESHOLD=0.3
SOURCE_INTEGRITY_SCAN_ENABLED=true
SOURCE_INTEGRITY_SCAN_TIMEOUT_MULTIPLIER=3.0
SOURCE_INTEGRITY_SCAN_MAX_ERRORS=40
VISUAL_DETECT_KEYFRAMES_ONLY=true
VISUAL_DETECT_FPS=2
VISUAL_DETECT_WIDTH=480

ASS_FONT_NAME=Microsoft YaHei
ASS_PRESET=classic
ASS_FONT_SIZE=56
ASS_PRIMARY_COLOR=&H00FFFFFF
ASS_OUTLINE_COLOR=&H00000000
ASS_BACK_COLOR=&H64000000
ASS_ALIGNMENT=2
ASS_MARGIN_V=90
ASS_OUTLINE=3
ASS_SHADOW=1
ASS_MAX_LINES=2
ASS_VERTICAL_FONT_SIZE=44

API_HOST=127.0.0.1
API_PORT=8765
API_PARALLEL_JOBS=2
API_BATCH_LIMIT=30
# Maximum total size for one browser upload request. 0 disables the limit.
# Recommended: 21474836480 (20 GiB). Prefer local file paths for larger batches.
RECORDING_UPLOAD_MAX_BYTES=21474836480
# Comma-separated extra browser origins allowed to call the local API.
# Keep empty for the built-in UI at http://127.0.0.1:8765.
# Example: API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5678
API_ALLOWED_ORIGINS=

LLM_PROVIDER=openai
LLM_MODEL=
LLM_TRANSLATION_BATCH_SIZE=24
LLM_TRANSLATION_BATCH_CHARS=6000
# Google AI Studio / Gemini native REST API (optional).
# Create a key in Google AI Studio, then use LLM_PROVIDER=google with a text model
# such as gemini-2.5-flash. The same key can also power Gemini image covers.
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

PUBLISH_ENABLED=false
PUBLISH_PROVIDERS=
BILIBILI_API_BASE_URL=
BILIBILI_VALIDATE_PATH=
BILIBILI_CREATE_UPLOAD_PATH=
BILIBILI_COMPLETE_UPLOAD_PATH=
BILIBILI_PUBLISH_PATH=
BILIBILI_QUERY_PATH=

EXPORT_PLATFORMS=douyin,bilibili,youtube_shorts
# Use h264_nvenc on NVIDIA GPUs for much faster preview/final rendering.
# Keep libx264 for maximum CPU-only compatibility.
RENDER_VIDEO_ENCODER=h264_nvenc
# Output 30fps by default to avoid VFR livestream timestamp drift.
# Set 0 to preserve the source timing.
RENDER_OUTPUT_FPS=30
# CPU x264 speed/quality knobs. CRF=0 keeps platform defaults; higher CRF is faster/smaller/lower quality.
RENDER_X264_PRESET=medium
RENDER_X264_CRF=0
RENDER_NVENC_PRESET=p5
RENDER_NVENC_CQ=21
RENDER_NVENC_PREVIEW_PRESET=p4
RENDER_NVENC_PREVIEW_CQ=25
# Lightweight proxy used only by the Web video player. final.mp4 remains full quality.
WEB_PREVIEW_ENABLED=true
WEB_PREVIEW_MAX_WIDTH=960
WEB_PREVIEW_MAX_HEIGHT=960
WEB_PREVIEW_FPS=24
WEB_PREVIEW_VIDEO_BITRATE=1200k
# Set BGM_PATH to an audio file to mix it into final.mp4 during render_final.
BGM_PATH=
BGM_VOLUME=0.16
SOURCE_AUDIO_VOLUME=1.0
WEBHOOK_URL=

COVER_PROVIDER=openai
COVER_MODEL=gpt-image-2
COVER_COUNT=3
COVER_ASPECTS=9:16,16:9
COVER_QUALITY=medium
COVER_OUTPUT_FORMAT=jpeg
COVER_TITLE_FONT=Microsoft YaHei
# AI cover generation can use official OpenAI, OpenAI-compatible Images API providers,
# OpenRouter, or Google AI Studio Gemini image models.
# Keep the default for official OpenAI.
# For a third-party provider, fill the provider's image-generation base URL, such as https://your-provider.example/v1.
# It must support POST {COVER_BASE_URL}/images/generations and return b64_json images.
# OpenRouter is special: set COVER_PROVIDER=openrouter, COVER_BASE_URL=https://openrouter.ai/api/v1,
# and choose a model with image output, such as google/gemini-2.5-flash-image.
# OpenRouter uses /chat/completions with COVER_MODALITIES=image,text and returns data URL images.
# Google AI Studio is native REST: set COVER_PROVIDER=google,
# COVER_MODEL=gemini-2.5-flash-image, and GOOGLE_API_KEY above.
# COVER_BASE_URL is ignored by the Google provider; GOOGLE_BASE_URL is used instead.
COVER_BASE_URL=https://api.openai.com/v1
# Preferred key for cover image generation. If empty, the selected provider falls back to
# OPENAI_API_KEY for OpenAI-style providers or GOOGLE_API_KEY for Google.
# This lets covers use a different third-party key from text LLM features.
COVER_API_KEY=
# Optional headers for third-party gateways. Leave blank unless your provider asks for them.
# For local use, a reasonable value is http://127.0.0.1:8765.
COVER_HTTP_REFERER=http://127.0.0.1:8765
# Optional human-readable app name header used by some third-party gateways.
COVER_APP_TITLE=Video Automation
# For OpenRouter image models, use image,text for multimodal models or image for image-only models.
COVER_MODALITIES=image,text
# Official OpenAI fallback key. Used by OpenAI text LLM features.
OPENAI_API_KEY=

# VERTICAL_MODE=blur preserves the whole foreground frame and fills 9:16 with a blurred background.
# Use pad for black bars, crop only when you intentionally want full-screen crop.
VERTICAL_MODE=blur
CROP_ANCHOR_X=0.5
CROP_ANCHOR_Y=0.5

# Optional future integrations. Leave blank if you do not use these tools.
# UVR_PATH points to an Ultimate Vocal Remover executable or launcher.
# Example: UVR_PATH=C:\Tools\UVR\UVR.exe
UVR_PATH=

# Native optional audio separation. Default is plan-only and keeps Lite builds small.
# Set AUDIO_SEPARATION_ENGINE=demucs only after installing Demucs in the active venv.
# Example install: .\venv\Scripts\python.exe -m pip install demucs
# Outputs are written to each job's uvr\vocals.wav and uvr\instrumental.wav.
AUDIO_SEPARATION_ENGINE=plan
DEMUCS_PATH=demucs
DEMUCS_MODEL=htdemucs
DEMUCS_DEVICE=auto
AUDIO_SEPARATION_TIMEOUT_SECONDS=7200
