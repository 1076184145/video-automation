VIDEO_AUTOMATION_ROOT=D:\video-automation
INPUT_RECORDINGS_DIR=D:\video-automation\input\recordings
INPUT_DOWNLOADS_DIR=D:\video-automation\input\downloads
JOBS_DIR=D:\video-automation\processing\jobs
LOGS_DIR=D:\video-automation\logs

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
AUDIOWAVEFORM_PATH=audiowaveform

WHISPER_BIN=whisper
WHISPER_BACKEND=faster-whisper
WHISPER_MODEL=large-v3
WHISPER_MODEL_FALLBACKS=large-v3-turbo,medium
WHISPER_LANGUAGE=zh
WHISPER_INITIAL_PROMPT=以下是中文直播录播，可能包含主播名、游戏术语、弹幕口语和网络用语。
WHISPER_TIMEOUT_MIN_SECONDS=300
WHISPER_TIMEOUT_MULTIPLIER=10
WHISPER_WORD_TIMESTAMPS=true
WHISPER_VAD_FILTER=true
FASTER_WHISPER_DEVICE=cuda
FASTER_WHISPER_COMPUTE_TYPE=int8_float16
FASTER_WHISPER_BATCH_SIZE=8

# Optional Chinese ASR backend. Set WHISPER_BACKEND=funasr to use it.
# First run downloads models through FunASR/ModelScope or Hugging Face.
FUNASR_MODEL=paraformer-zh
FUNASR_VAD_MODEL=fsmn-vad
FUNASR_PUNC_MODEL=ct-punc
FUNASR_DEVICE=cuda:0
FUNASR_HOTWORDS=
FUNASR_BATCH_SIZE_S=300
FUNASR_MAX_SEGMENT_MS=60000

# Optional ffmpeg filter applied only to audio.wav used for transcription.
# Example: highpass=f=80,lowpass=f=7600,afftdn
TRANSCRIBE_AUDIO_FILTER=

PROFANITY_WORDS=操,艹,卧槽,我操,傻逼,牛逼,装逼,妈的,他妈的,草泥马
SUBTITLE_CENSOR_REPLACEMENT=[哔]
SUBTITLE_REPLACEMENTS=酒馆占棋=>酒馆战棋
SUBTITLE_MIN_DURATION_SECONDS=0.3

FILE_STABLE_SECONDS=8
POLL_INTERVAL_SECONDS=5
SILENCE_MIN_LENGTH_SECONDS=0.8
SILENCE_MIN_GAP_SECONDS=0.35
CUT_MIN_CLIP_SECONDS=2.0
CUT_MERGE_GAP_SECONDS=1.5
SILENCE_THRESHOLD_DB=-35
FREEZE_NOISE_DB=-60
FREEZE_MIN_DURATION_SECONDS=2
SCENE_THRESHOLD=0.3
VISUAL_DETECT_KEYFRAMES_ONLY=true
VISUAL_DETECT_FPS=2
VISUAL_DETECT_WIDTH=480

ASS_FONT_NAME=Microsoft YaHei
ASS_PRESET=classic
ASS_FONT_SIZE=56
ASS_PRIMARY_COLOR=&H00FFFFFF
ASS_OUTLINE_COLOR=&H00000000
ASS_BACK_COLOR=&H64000000
ASS_ALIGNMENT=2
ASS_MARGIN_V=90
ASS_OUTLINE=3
ASS_SHADOW=1
ASS_MAX_LINES=2
ASS_VERTICAL_FONT_SIZE=44

API_HOST=127.0.0.1
API_PORT=8765
API_PARALLEL_JOBS=2
# Comma-separated extra browser origins allowed to call the local API.
# Keep empty for the built-in UI at http://127.0.0.1:8765.
# Example: API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5678
API_ALLOWED_ORIGINS=

DOWNLOAD_ENABLED=false
YTDLP_PATH=yt-dlp

LLM_PROVIDER=openai
LLM_MODEL=

PUBLISH_ENABLED=false
PUBLISH_PROVIDERS=

EXPORT_PLATFORMS=douyin,bilibili,youtube_shorts
# Use h264_nvenc on NVIDIA GPUs for much faster preview/final rendering.
# Keep libx264 for maximum CPU-only compatibility.
RENDER_VIDEO_ENCODER=h264_nvenc
RENDER_NVENC_PRESET=p5
RENDER_NVENC_CQ=21
RENDER_NVENC_PREVIEW_PRESET=p4
RENDER_NVENC_PREVIEW_CQ=25
# Set BGM_PATH to an audio file to mix it into final.mp4 during render_final.
BGM_PATH=
BGM_VOLUME=0.16
SOURCE_AUDIO_VOLUME=1.0
WEBHOOK_URL=

COVER_PROVIDER=openai
COVER_MODEL=gpt-image-2
COVER_COUNT=3
COVER_ASPECTS=9:16,16:9
COVER_QUALITY=medium
COVER_OUTPUT_FORMAT=jpeg
COVER_TITLE_FONT=Microsoft YaHei
OPENAI_API_KEY=

# VERTICAL_MODE=blur preserves the whole foreground frame and fills 9:16 with a blurred background.
# Use pad for black bars, crop only when you intentionally want full-screen crop.
VERTICAL_MODE=blur
CROP_ANCHOR_X=0.5
CROP_ANCHOR_Y=0.5

UVR_PATH=
FACE_SWAP_PATH=
AIFACECOVER_ROOT=
